---
import Layout from '../layouts/Layout.astro';

// En Vercel (Prod), el backend está en /api
// En Local, usar http://localhost:8000
const API_BASE = import.meta.env.PROD 
	? '/api' // URL relativa en producción
	: 'http://localhost:8000';

const jobs = [];
---

<Layout title="StgoJobsDash | Dashboard Premium">
	<header class="dashboard-header animate-fade-in">
		<div class="header-content">
			<h1>StgoJobsDash <span class="badge">V3</span></h1>
			<p>Ecosistema de búsqueda optimizado para <span>chiletrabajos.cl</span></p>
		</div>
		<div class="metrics-row">
			<div class="metric">
				<span class="label">Vacantes</span>
				<span class="value" id="totalJobs">0</span>
			</div>
			<div class="metric alt">
				<span class="label">Postulados</span>
				<span class="value" id="appliedCount">0</span>
			</div>
			<div class="metric accent">
				<span class="label">Remoto %</span>
				<span class="value" id="remotePercent">0%</span>
			</div>
		</div>
	</header>

	<div class="dashboard-grid">
		<aside class="sidebar animate-fade-in">
			<div class="sidebar-section">
				<h3>Scraper Control</h3>
				<div class="input-group">
					<input type="text" id="queryInput" placeholder="Ej: Python Developer" />
					<button id="scrapeBtn" class="btn btn-accent">Scrapear</button>
				</div>
				<p class="hint">Extrae 3 páginas de Chiletrabajos.cl</p>
			</div>

			<div class="sidebar-section">
				<h3>Filtros Avanzados</h3>
				<label class="checkbox-container">
					Ocultar Postulados
					<input type="checkbox" id="hideApplied" />
					<span class="checkmark"></span>
				</label>
				
				<label class="range-container">
					Matching Score Mínimo
					<input type="range" id="scoreRange" min="0" max="100" value="0" />
					<span id="scoreVal">0%</span>
				</label>
			</div>

			<div class="sidebar-section">
				<h3>CV para Matching</h3>
				<textarea id="cvText" placeholder="Pega tu CV (texto) aquí para calcular el match score..."></textarea>
				<button id="matchingBtn" class="btn btn-secondary">Actualizar Scores</button>
			</div>
		</aside>

		<main class="jobs-list">
			<div class="list-header">
				<h2>Ofertas Recientes</h2>
				<span id="resultsCount">0 resultados</span>
			</div>
			<div id="jobsContainer" class="jobs-grid">
				<div class="no-jobs">
					<p>No hay ofertas disponibles. Usa el scraper para buscar empleos.</p>
				</div>
			</div>
		</main>
	</div>
</Layout>

<style>
	.dashboard-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border-color);
	}

	.dashboard-header h1 {
		font-size: 2.5rem;
		font-weight: 800;
		background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		letter-spacing: -1px;
	}

	.badge {
		font-size: 0.9rem;
		padding: 0.2rem 0.5rem;
		background: var(--accent-secondary);
		-webkit-text-fill-color: white;
		border-radius: 6px;
		vertical-align: middle;
	}

	.header-content p {
		color: var(--text-secondary);
		margin-top: 0.5rem;
	}

	.header-content p span {
		color: var(--text-primary);
		font-weight: 600;
	}

	.metrics-row {
		display: flex;
		gap: 1.5rem;
	}

	.metric {
		background: var(--bg-secondary);
		padding: 1rem 1.75rem;
		border-radius: 12px;
		display: flex;
		flex-direction: column;
		min-width: 140px;
		border: 1px solid var(--border-color);
	}

	.metric.accent { border-color: var(--accent-primary); }
	.metric.alt { border-color: var(--accent-secondary); }

	.metric .label {
		color: var(--text-secondary);
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.metric .value {
		font-size: 1.75rem;
		font-weight: 700;
		margin-top: 0.25rem;
	}

	.dashboard-grid {
		display: grid;
		grid-template-columns: 320px 1fr;
		gap: 2.5rem;
	}

	.sidebar {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.sidebar-section {
		background: var(--bg-secondary);
		padding: 1.5rem;
		border-radius: 16px;
		border: 1px solid var(--border-color);
	}

	.sidebar-section h3 {
		font-size: 1rem;
		margin-bottom: 1rem;
		color: var(--text-primary);
	}

	.input-group {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 0.5rem;
	}

	input[type="text"], textarea {
		background: var(--bg-primary);
		border: 1px solid var(--border-color);
		border-radius: 10px;
		color: white;
		padding: 0.75rem;
		width: 100%;
		font-family: 'Inter', sans-serif;
	}

	textarea {
		height: 120px;
		resize: none;
		margin-bottom: 0.75rem;
		font-size: 0.85rem;
	}

	.btn {
		cursor: pointer;
		font-weight: 600;
		transition: var(--transition-smooth);
		border: none;
	}

	.btn-accent {
		background: var(--accent-secondary);
		color: white;
		padding: 0 1rem;
		border-radius: 10px;
	}

	.btn-secondary {
		background: var(--bg-primary);
		color: var(--accent-primary);
		border: 1px solid var(--accent-primary);
		padding: 0.75rem;
		width: 100%;
		border-radius: 10px;
	}

	.hint {
		font-size: 0.75rem;
		color: var(--text-secondary);
	}

	.checkbox-container {
		display: block;
		position: relative;
		padding-left: 35px;
		margin-bottom: 1rem;
		cursor: pointer;
		font-size: 0.9rem;
		user-select: none;
	}

	.checkbox-container input { visibility: hidden; position: absolute; }

	.checkmark {
		position: absolute;
		top: 0;
		left: 0;
		height: 20px;
		width: 20px;
		background-color: var(--bg-primary);
		border: 1px solid var(--border-color);
		border-radius: 5px;
	}

	.checkbox-container input:checked ~ .checkmark {
		background-color: var(--accent-secondary);
		border-color: var(--accent-secondary);
	}

	.checkmark:after {
		content: "";
		position: absolute;
		display: none;
		left: 6px;
		top: 2px;
		width: 5px;
		height: 10px;
		border: solid white;
		border-width: 0 2px 2px 0;
		transform: rotate(45deg);
	}

	.checkbox-container input:checked ~ .checkmark:after { display: block; }

	.range-container {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		font-size: 0.9rem;
	}

	.jobs-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.list-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.list-header h2 { font-size: 1.5rem; font-weight: 700; }
	#resultsCount { color: var(--text-secondary); font-size: 0.9rem; }

	.jobs-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
		gap: 1.5rem;
	}

	.no-jobs {
		grid-column: 1 / -1;
		text-align: center;
		padding: 3rem;
		color: var(--text-secondary);
		font-size: 1.1rem;
	}

	.job-card {
		background: var(--card-bg);
		border: 1px solid var(--border-color);
		border-radius: 16px;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		transition: var(--transition-smooth);
		position: relative;
		overflow: hidden;
	}

	.job-card:hover {
		transform: translateY(-4px);
		border-color: var(--accent-secondary);
		box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 
		            0 0 15px -2px rgba(0, 112, 243, 0.2);
	}

	.applied {
		opacity: 0.6;
		filter: grayscale(0.5);
	}

	.header-main {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.title {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--text-primary);
	}

	.company {
		color: var(--accent-primary);
		font-weight: 600;
		font-size: 0.9rem;
		letter-spacing: 0.5px;
		margin-bottom: 0.5rem;
	}

	.job-snippet {
		font-size: 0.85rem;
		color: var(--text-secondary);
		line-height: 1.4;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		margin-bottom: 0.5rem;
	}

	.score-badge {
		background: rgba(0, 0, 0, 0.3);
		padding: 0.5rem 0.75rem;
		border-radius: 8px;
		border: 1px solid var(--score-color);
		color: var(--score-color);
		font-weight: 700;
		font-size: 0.85rem;
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
	}

	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.tag {
		background: var(--bg-secondary);
		padding: 0.4rem 0.8rem;
		border-radius: 8px;
		font-size: 0.8rem;
		color: var(--text-secondary);
		border: 1px solid transparent;
	}

	.modality.remoto {
		color: var(--accent-primary);
		background: rgba(0, 242, 141, 0.1);
		border-color: rgba(0, 242, 141, 0.2);
	}

	.card-footer {
		display: flex;
		gap: 0.75rem;
		margin-top: auto;
	}

	.btn {
		padding: 0.6rem 1.2rem;
		border-radius: 10px;
		font-weight: 600;
		font-size: 0.9rem;
		cursor: pointer;
		transition: var(--transition-smooth);
		text-decoration: none;
		text-align: center;
		flex: 1;
		border: none;
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--accent-secondary), #0056b3);
		color: white;
	}

	.btn-primary:hover {
		filter: brightness(1.1);
		transform: scale(1.02);
	}

	.btn-secondary {
		background: var(--bg-secondary);
		color: var(--text-primary);
		border: 1px solid var(--border-color);
	}

	.btn-secondary:hover {
		border-color: var(--text-secondary);
	}
</style>

<script>
	// Interactivity and dynamic fetching
	// En Vercel (Prod), el backend está en /api
	// En Local, usar http://localhost:8000
	const API_BASE = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
		? 'http://localhost:8000'
		: '/api';

	const scrapeBtn = document.getElementById('scrapeBtn') as HTMLButtonElement;
	const queryInput = document.getElementById('queryInput') as HTMLInputElement;
	const matchingBtn = document.getElementById('matchingBtn') as HTMLButtonElement;
	const cvText = document.getElementById('cvText') as HTMLTextAreaElement;
	const hideApplied = document.getElementById('hideApplied') as HTMLInputElement;
	const scoreRange = document.getElementById('scoreRange') as HTMLInputElement;
	const scoreVal = document.getElementById('scoreVal') as HTMLSpanElement;
	const jobsContainer = document.getElementById('jobsContainer') as HTMLElement;

	async function loadJobs() {
		try {
			const response = await fetch(`${API_BASE}/jobs?include_applied=true`);
			if (response.ok) {
				const jobs = await response.json();
				updateMetrics(jobs);
				renderJobs(jobs);
			} else {
				console.error('Load failed:', response.status);
			}
		} catch (err) {
			console.error('Error loading jobs:', err);
		}
	}

	function updateMetrics(jobs: any[]) {
		const totalJobs = jobs.length;
		const appliedCount = jobs.filter((j: any) => j.aplicado).length;
		const remotePercent = totalJobs > 0 
			? Math.round((jobs.filter((j: any) => j.modalidad === 'Remoto').length / totalJobs) * 100) 
			: 0;
		
		const totalJobsEl = document.getElementById('totalJobs');
		const appliedCountEl = document.getElementById('appliedCount');
		const remotePercentEl = document.getElementById('remotePercent');
		const resultsCountEl = document.getElementById('resultsCount');
		
		if (totalJobsEl) totalJobsEl.textContent = totalJobs.toString();
		if (appliedCountEl) appliedCountEl.textContent = appliedCount.toString();
		if (remotePercentEl) remotePercentEl.textContent = `${remotePercent}%`;
		if (resultsCountEl) resultsCountEl.textContent = `${totalJobs} resultados`;
	}

	function attachApplyListeners() {
		document.querySelectorAll('.apply-btn').forEach((btn: Element) => {
			const button = btn as HTMLButtonElement;
			if (button.hasAttribute('data-listener-attached')) return;
			button.setAttribute('data-listener-attached', 'true');
			
			button.addEventListener('click', async (e) => {
				const card = button.closest('.job-card') as HTMLElement;
				if (!card) return;
				
				const id = card.dataset.id;
				if (!id) {
					console.error('No job ID found');
					return;
				}
				
				const isApplied = button.dataset.applied === 'true';
				
				button.disabled = true;
				const originalText = button.textContent;
				button.textContent = 'Actualizando...';
				
				try {
					const response = await fetch(`${API_BASE}/jobs/${id}/apply`, {
						method: 'PATCH',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ aplicado: !isApplied })
					});
					
					if (response.ok) {
						const newState = !isApplied;
						button.dataset.applied = newState.toString();
						button.textContent = newState ? 'Postulado ✓' : 'Marcar Postulado';
						card.classList.toggle('applied', newState);
					} else {
						console.error('Failed to update status:', response.status, response.statusText);
						button.textContent = originalText;
					}
				} catch (err) {
					console.error('Error updating status:', err);
					button.textContent = originalText;
				} finally {
					button.disabled = false;
				}
			});
		});
	}

	function generateJobHTML(job: any) {
		const formattedDate = job.fecha_publicacion ? new Date(job.fecha_publicacion).toLocaleDateString('es-CL', { day: '2-digit', month: 'short' }) : 'Fecha no disponible';
		const scoreColor = (job.matching_score >= 80) ? 'var(--accent-primary)' : (job.matching_score >= 50) ? 'var(--accent-secondary)' : 'var(--text-secondary)';
		const modalityClass = job.modalidad ? job.modalidad.toLowerCase() : '';
		const displayModality = job.modalidad || 'No especificado';
		
		return `
			<article class="job-card ${job.aplicado ? 'applied' : ''}" data-id="${job.id || ''}" data-link="${job.link || '#'}">
				<div class="card-header">
					<div class="header-main">
						<h3 class="title">${job.titulo || 'Título no disponible'}</h3>
						<p class="company">${job.empresa || 'Empresa no disponible'}</p>
					</div>
					${job.descripcion ? `<p class="job-snippet">${job.descripcion}</p>` : ''}
					${job.matching_score > 0 ? `<div class="score-badge" style="--score-color: ${scoreColor}"><span>${Math.round(job.matching_score)}% Match</span></div>` : ''}
				</div>
				<div class="card-body">
					<div class="tag-row">
						<span class="tag">📅 ${formattedDate}</span>
						<span class="tag modality ${modalityClass}">${displayModality}</span>
						<span class="tag salary">${job.sueldo_estimado || 'No especificado'}</span>
					</div>
				</div>
				<div class="card-footer">
					<a href="${job.link || '#'}" target="_blank" class="btn btn-secondary">Ver Oferta</a>
					<button class="btn btn-primary apply-btn" data-applied="${job.aplicado ? 'true' : 'false'}" data-id="${job.id || ''}">${job.aplicado ? 'Postulado ✓' : 'Marcar Postulado'}</button>
				</div>
			</article>
		`;
	}

	function renderJobs(jobs: any[]) {
		if (!jobsContainer) return;
		
		const html = jobs.length > 0 ? jobs.map(generateJobHTML).join('') : '<div class="no-jobs"><p>No hay ofertas disponibles. Usa el scraper para buscar empleos.</p></div>';
		
		jobsContainer.innerHTML = html;
		attachApplyListeners();
	}

	async function filterJobs() {
		try {
			const hide = (hideApplied as HTMLInputElement)?.checked || false;
			const minScore = parseInt((scoreRange as HTMLInputElement)?.value || '0');
			
			const response = await fetch(`${API_BASE}/jobs?include_applied=${!hide}&min_score=${minScore}`);
			if (response.ok) {
				const jobs = await response.json();
				updateMetrics(jobs);
				renderJobs(jobs);
			} else {
				console.error('Filter failed:', response.status);
			}
		} catch (err) {
			console.error('Error filtering jobs:', err);
		}
	}

	if (scoreRange && scoreVal) {
		scoreRange.addEventListener('input', (e) => {
			const target = e.target as HTMLInputElement;
			scoreVal.textContent = `${target.value}%`;
			filterJobs();
		});
	}

	if (hideApplied) {
		hideApplied.addEventListener('change', filterJobs);
	}

	scrapeBtn.addEventListener('click', async () => {
		if (!scrapeBtn || !queryInput) return;
		
		scrapeBtn.disabled = true;
		const originalText = scrapeBtn.textContent;
		scrapeBtn.textContent = 'Buscando...';
		const query = (queryInput as HTMLInputElement).value?.trim() || 'Python';
		
		try {
			const response = await fetch(`${API_BASE}/scrape?query=${encodeURIComponent(query)}`);
			if (response.ok) {
				location.reload();
			} else {
				console.error('Scrape failed:', response.status);
				scrapeBtn.textContent = originalText;
			}
		} catch (err) {
			console.error('Error scraping:', err);
			scrapeBtn.textContent = originalText;
		} finally {
			scrapeBtn.disabled = false;
		}
	});

	matchingBtn.addEventListener('click', async () => {
		if (!matchingBtn || !cvText) return;
		
		matchingBtn.disabled = true;
		const originalText = matchingBtn.textContent;
		matchingBtn.textContent = 'Procesando...';
		
		try {
			const response = await fetch(`${API_BASE}/matching`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ cv_text: (cvText as HTMLTextAreaElement).value || '' })
			});
			if (response.ok) {
				location.reload();
			} else {
				console.error('Matching failed:', response.status);
				matchingBtn.textContent = originalText;
			}
		} catch (err) {
			console.error('Error matching:', err);
			matchingBtn.textContent = originalText;
		} finally {
			matchingBtn.disabled = false;
		}
	});

	document.addEventListener('DOMContentLoaded', loadJobs);
</script>
