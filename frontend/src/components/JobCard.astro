---
interface Props {
	id: string;
	title: string;
	company: string;
	link: string;
	date: string;
	modality: string;
	salary: string;
	score: number;
	applied: boolean;
	description?: string;
}

const { id, title, company, link, date, modality, salary, score, applied, description } = Astro.props;

// Formatear fecha
const formattedDate = new Date(date).toLocaleDateString('es-CL', {
	day: '2-digit',
	month: 'short'
});

const scoreColor = score >= 80 ? 'var(--accent-primary)' : score >= 50 ? 'var(--accent-secondary)' : 'var(--text-secondary)';
---

<article class={`job-card ${applied ? 'applied' : ''}`} data-id={id} data-link={link}>
	<div class="card-header">
		<div class="header-main">
			<h3 class="title">{title}</h3>
			<p class="company">{company}</p>
		</div>
		{description && <p class="job-snippet">{description}</p>}
		{score > 0 && (
			<div class="score-badge" style={`--score-color: ${scoreColor}`}>
				<span>{score}% Match</span>
			</div>
		)}
	</div>

	<div class="card-body">
		<div class="tag-row">
			<span class="tag"><i class="icon-calendar"></i> {formattedDate}</span>
			<span class={`tag modality ${modality.toLowerCase()}`}>{modality}</span>
			<span class="tag salary">{salary}</span>
		</div>
	</div>

	<div class="card-footer">
		<a href={link} target="_blank" class="btn btn-secondary">Ver Oferta</a>
		<button class="btn btn-primary apply-btn" data-applied={applied}>
			{applied ? 'Postulado ✓' : 'Marcar Postulado'}
		</button>
	</div>
</article>

<style>
	.job-card {
		background: var(--card-bg);
		border: 1px solid var(--border-color);
		border-radius: 16px;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		transition: var(--transition-smooth);
		position: relative;
		overflow: hidden;
	}

	.job-card:hover {
		transform: translateY(-4px);
		border-color: var(--accent-secondary);
		box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 
		            0 0 15px -2px rgba(0, 112, 243, 0.2);
	}

	.applied {
		opacity: 0.6;
		filter: grayscale(0.5);
	}

	.header-main {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.title {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--text-primary);
	}

	.company {
		color: var(--accent-primary);
		font-weight: 600;
		font-size: 0.9rem;
		letter-spacing: 0.5px;
		margin-bottom: 0.5rem;
	}

	.job-snippet {
		font-size: 0.85rem;
		color: var(--text-secondary);
		line-height: 1.4;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		margin-bottom: 0.5rem;
	}

	.score-badge {
		background: rgba(0, 0, 0, 0.3);
		padding: 0.5rem 0.75rem;
		border-radius: 8px;
		border: 1px solid var(--score-color);
		color: var(--score-color);
		font-weight: 700;
		font-size: 0.85rem;
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
	}

	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.tag {
		background: var(--bg-secondary);
		padding: 0.4rem 0.8rem;
		border-radius: 8px;
		font-size: 0.8rem;
		color: var(--text-secondary);
		border: 1px solid transparent;
	}

	.modality.remoto {
		color: var(--accent-primary);
		background: rgba(0, 242, 141, 0.1);
		border-color: rgba(0, 242, 141, 0.2);
	}

	.card-footer {
		display: flex;
		gap: 0.75rem;
		margin-top: auto;
	}

	.btn {
		padding: 0.6rem 1.2rem;
		border-radius: 10px;
		font-weight: 600;
		font-size: 0.9rem;
		cursor: pointer;
		transition: var(--transition-smooth);
		text-decoration: none;
		text-align: center;
		flex: 1;
		border: none;
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--accent-secondary), #0056b3);
		color: white;
	}

	.btn-primary:hover {
		filter: brightness(1.1);
		transform: scale(1.02);
	}

	.btn-secondary {
		background: var(--bg-secondary);
		color: var(--text-primary);
		border: 1px solid var(--border-color);
	}

	.btn-secondary:hover {
		border-color: var(--text-secondary);
	}
</style>

<script>
	// Client-side logic for the "Apply" button
	document.querySelectorAll('.apply-btn').forEach(btn => {
		btn.addEventListener('click', async (e) => {
			const card = btn.closest('.job-card');
			const id = card.dataset.id;
			const isApplied = btn.dataset.applied === 'true';
			
			try {
				const response = await fetch(`http://localhost:8000/jobs/${id}/apply`, {
					method: 'PATCH',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ aplicado: !isApplied })
				});
				
				if (response.ok) {
					const newState = !isApplied;
					btn.dataset.applied = newState.toString();
					btn.textContent = newState ? 'Postulado ✓' : 'Marcar Postulado';
					card.classList.toggle('applied', newState);
				}
			} catch (err) {
				console.error('Error updating status:', err);
			}
		});
	});
</script>
